---
import "../css/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Architects+Daughter&family=Caveat:wght@400..700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/Cortlink-icon.png" />
	<meta property="og:image" content="/Cortlink-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>CortLink</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  body {
    max-width: 1950px;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-self: center;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  h2,
  h3,
  h4,
  h5, a {
    font-family: "Architects Daughter", cursive;
    font-weight: 400;
    font-style: normal;
  }

  :root {
    --Black: #000;
    --White: #fff;
    --White_Light: #f5f5f5;
    --blue: #605abb;
    --Blue_light: #a0f8de;
    --Black_light: #16161694;
  }
</style>
